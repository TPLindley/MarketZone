<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mzConfigure.MainPage"
             Title="MarketZone Config">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Header -->
            <Label 
                Text="Rolling Pin Bakery"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#FF1595"
                Margin="0,10,0,20"/>

            <!-- Connection Section -->
            <Border Stroke="LightGray" Padding="15" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Raspberry Pi Connection" FontSize="18" FontAttributes="Bold"/>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="URL:" VerticalOptions="Center"/>
                        <Entry 
                            x:Name="UrlEntry"
                            Text="{Binding RaspberryPiUrl}"
                            Placeholder="http://raspberrypi.local:8765"
                            HorizontalOptions="Fill"/>
                    </HorizontalStackLayout>

                    <Button 
                        Text="Test Connection"
                        Command="{Binding TestConnectionCommand}"
                        BackgroundColor="#FF1595"
                        TextColor="White"/>
                </VerticalStackLayout>
            </Border>

            <!-- Status -->
            <Label 
                Text="{Binding Status}"
                FontSize="14"
                HorizontalOptions="Center"
                TextColor="Gray"/>

            <ActivityIndicator 
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}"
                Color="#FF1595"
                HorizontalOptions="Center"/>

            <!-- Actions -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Button 
                    Text="Load from Display"
                    Command="{Binding LoadSpecialsCommand}"
                    BackgroundColor="DarkGreen"
                    TextColor="White"/>

                <Button 
                    Text="Clear Display"
                    Command="{Binding ClearSpecialsCommand}"
                    BackgroundColor="DarkRed"
                    TextColor="White"/>
            </HorizontalStackLayout>

            <!-- Specials List -->
            <Border Stroke="LightGray" Padding="15" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="10">
                        <Label 
                            Text="Specials List" 
                            FontSize="18" 
                            FontAttributes="Bold"
                            HorizontalOptions="Start"
                            VerticalOptions="Center"/>
                        <Button 
                            Text="+ Add"
                            Command="{Binding AddSpecialCommand}"
                            BackgroundColor="#FF1595"
                            TextColor="White"
                            Padding="10,5"
                            HorizontalOptions="End"/>
                    </HorizontalStackLayout>

                    <CollectionView 
                        ItemsSource="{Binding Specials}"
                        SelectionMode="None"
                        HeightRequest="300">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border 
                                    Stroke="LightGray" 
                                    Padding="10" 
                                    Margin="0,5"
                                    StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="5"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                                            <Entry 
                                                Text="{Binding Text}"
                                                Placeholder="Special text"/>
                                            <HorizontalStackLayout Spacing="5">
                                                <Label Text="Color:" VerticalOptions="Center"/>
                                                <Entry 
                                                    Text="{Binding Color}"
                                                    Placeholder="#FFFFFF"
                                                    WidthRequest="100"/>
                                                <BoxView 
                                                    Color="{Binding Color}"
                                                    WidthRequest="30"
                                                    HeightRequest="30"
                                                    CornerRadius="5"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <Button 
                                            Grid.Column="2"
                                            Text="✕"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveSpecialCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="Red"
                                            TextColor="White"
                                            WidthRequest="40"
                                            VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label 
                                Text="No specials. Add some or load from display."
                                HorizontalOptions="Center"
                                TextColor="Gray"
                                Margin="0,20"/>
                        </CollectionView.EmptyView>
                    </CollectionView>

                    <Button 
                        Text="Update Display"
                        Command="{Binding UpdateSpecialsCommand}"
                        BackgroundColor="DarkBlue"
                        TextColor="White"
                        Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
