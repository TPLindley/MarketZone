<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mzConfigure.MainPage"
             Title="{Binding PageTitle}">

    <Grid Padding="10" RowDefinitions="*,Auto">

        <!-- Status Bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,10">
            <Label 
                Grid.Column="0"
                Text="{Binding Status}"
                FontSize="14"
                VerticalOptions="Center"
                TextColor="Gray"/>
            <ActivityIndicator 
                Grid.Column="1"
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}"
                Color="#FF1595"
                WidthRequest="20"
                HeightRequest="20"/>
        </Grid>

        <!-- Specials List with Action Buttons -->
        <Border Grid.Row="0" Stroke="LightGray" Padding="15" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10"/>
            </Border.StrokeShape>
            <Grid RowDefinitions="Auto,*" RowSpacing="10">
                <!-- Header with Action Buttons -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Label 
                        Grid.Column="0"
                        Text="Specials List" 
                        FontSize="18" 
                        FontAttributes="Bold"
                        VerticalOptions="Center"/>

                    <!-- Action Buttons on the Right -->
                    <HorizontalStackLayout Grid.Column="1" Spacing="8">
                        <Button 
                            Text="Add"
                            Command="{Binding AddSpecialCommand}"
                            IsEnabled="{Binding IsConnected}"
                            BackgroundColor="#FF1595"
                            TextColor="White"
                            Padding="12,8"
                            FontSize="12"/>
                        <Button 
                            Text="Update"
                            Command="{Binding UpdateSpecialsCommand}"
                            IsEnabled="{Binding IsConnected}"
                            BackgroundColor="DarkBlue"
                            TextColor="White"
                            Padding="12,8"
                            FontSize="12"/>
                        <Button 
                            Text="Load"
                            Command="{Binding LoadSpecialsCommand}"
                            IsEnabled="{Binding IsConnected}"
                            BackgroundColor="DarkGreen"
                            TextColor="White"
                            Padding="12,8"
                            FontSize="12"/>
                        <Button 
                            Text="Clear"
                            Command="{Binding ClearSpecialsCommand}"
                            IsEnabled="{Binding IsConnected}"
                            BackgroundColor="DarkRed"
                            TextColor="White"
                            Padding="12,8"
                            FontSize="12"/>
                        <Button 
                            Text="Header"
                            Command="{Binding HeaderCommand}"
                            BackgroundColor="DarkBlue"
                            TextColor="White"
                            Padding="12,8"
                            FontSize="12"/>
                        <Button 
                            Text="WiFi"
                            Command="{Binding WiFiCommand}"
                            BackgroundColor="DarkOrange"
                            TextColor="White"
                            Padding="12,8"
                            FontSize="12"/>
                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                            <Label
                                Text="{Binding OrientationText}"
                                FontSize="12"
                                VerticalOptions="Center"/>
                            <Switch
                                IsToggled="{Binding IsPortrait}"
                                IsEnabled="{Binding IsConnected}"
                                VerticalOptions="Center"
                                OnColor="#FF00FF"
                                ThumbColor="White"/>
                        </HorizontalStackLayout>
                        <Button 
                            Text="{Binding ConnectButtonText}"
                            Command="{Binding ConnectCommand}"
                            BackgroundColor="{Binding ConnectButtonColor}"
                            TextColor="White"
                            Padding="12,8"
                            FontSize="12"/>
                    </HorizontalStackLayout>
                </Grid>

                <!-- Collection View -->
                <CollectionView 
                    Grid.Row="1"
                    ItemsSource="{Binding Specials}"
                    SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border 
                                Stroke="LightGray" 
                                Padding="10" 
                                Margin="0,5"
                                StrokeThickness="1"
                                BackgroundColor="Black">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="5"/>
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                    <!-- Editable Text Entry with Color -->
                                    <Entry 
                                        Grid.Column="0"
                                        Text="{Binding Text}"
                                        Placeholder="Special text"
                                        TextColor="{Binding ColorValue}"
                                        BackgroundColor="Black"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        HorizontalOptions="FillAndExpand"
                                        VerticalOptions="Center"/>

                                    <!-- Color Picker Button -->
                                    <Button 
                                        Grid.Column="1"
                                        Text="🎨"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PickColorCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#FF1595"
                                        TextColor="White"
                                        WidthRequest="45"
                                        HeightRequest="45"
                                        CornerRadius="5"
                                        Padding="0"
                                        VerticalOptions="Center"/>

                                    <!-- Delete Button -->
                                    <Button 
                                        Grid.Column="2"
                                        Text="✕"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveSpecialCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Red"
                                        TextColor="White"
                                        WidthRequest="45"
                                        HeightRequest="45"
                                        CornerRadius="5"
                                        Padding="0"
                                        VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label 
                            Text="No specials. Use 'Load' to fetch from display or 'Add' to create new."
                            HorizontalOptions="Center"
                            TextColor="Gray"
                            Margin="0,40"/>
                    </CollectionView.EmptyView>
                </CollectionView>
            </Grid>
        </Border>

    </Grid>

</ContentPage>
