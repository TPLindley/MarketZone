<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
	<!-- Allow cleartext (HTTP) traffic to local network addresses -->
	<domain-config cleartextTrafficPermitted="true">
		<!-- Local Pi on hotspot network -->
		<domain includeSubdomains="false">10.42.0.1</domain>

		<!-- Common local network ranges (in case you use different IPs) -->
		<domain includeSubdomains="true">192.168.0.0</domain>
		<domain includeSubdomains="true">192.168.1.0</domain>
		<domain includeSubdomains="true">192.168.4.0</domain>
		<domain includeSubdomains="true">192.168.43.0</domain>
		<domain includeSubdomains="true">10.0.0.0</domain>

		<!-- Allow raspberrypi.local hostname -->
		<domain includeSubdomains="false">raspberrypi.local</domain>
		<domain includeSubdomains="false">localhost</domain>
	</domain-config>
</network-security-config>
