<?xml version="1.0" encoding="utf-8"?>
<Project>

  <!-- Property Group for Build Number Management -->
  <PropertyGroup>
	<BuildNumberFile>$(MSBuildThisFileDirectory)build.number</BuildNumberFile>
	<GeneratedVersionFile>$(MSBuildThisFileDirectory)Version.g.cs</GeneratedVersionFile>
  </PropertyGroup>

  <!-- Target: Read Build Number Before Compilation -->
  <Target Name="ReadBuildNumber" BeforeTargets="BeforeBuild;CoreCompile">
	<!-- Read the current build number from file -->
	<ReadLinesFromFile File="$(BuildNumberFile)" Condition="Exists('$(BuildNumberFile)')">
	  <Output TaskParameter="Lines" PropertyName="BuildNumber" />
	</ReadLinesFromFile>

	<!-- Default to 1 if file doesn't exist -->
	<PropertyGroup>
	  <BuildNumber Condition="'$(BuildNumber)' == ''">1</BuildNumber>
	</PropertyGroup>

	<!-- Compute the full version string for use in project properties -->
	<PropertyGroup>
	  <VersionMajor>1</VersionMajor>
	  <VersionMinor>0</VersionMinor>
	  <ComputedVersion>$(VersionMajor).$(VersionMinor).$(BuildNumber)</ComputedVersion>
	  <ApplicationDisplayVersion>$(ComputedVersion)</ApplicationDisplayVersion>
	  <ApplicationVersion>$(BuildNumber)</ApplicationVersion>
	  <Version>$(ComputedVersion)</Version>
	  <AssemblyVersion>$(ComputedVersion)</AssemblyVersion>
	  <FileVersion>$(ComputedVersion)</FileVersion>
	</PropertyGroup>

	<!-- Generate Version.g.cs file with actual build number -->
	<PropertyGroup>
	  <VersionFileContent>
<![CDATA[// <auto-generated />
// This file is generated automatically during build. Do not edit manually.
namespace MarketZone%3B

/// <summary>
/// Centralized version information for all MarketZone applications.
/// Major and Minor versions are defined as constants.
/// Build number is automatically incremented by the build system.
/// </summary>
public static class AppVersion
{
	/// <summary>
	/// Major version number - update manually in Directory.Build.targets for breaking changes or major releases.
	/// </summary>
	public const int Major = $(VersionMajor)%3B

	/// <summary>
	/// Minor version number - update manually in Directory.Build.targets for feature additions or minor releases.
	/// </summary>
	public const int Minor = $(VersionMinor)%3B

	/// <summary>
	/// Build number - automatically incremented on each successful build.
	/// </summary>
	public const int Build = $(BuildNumber)%3B

	/// <summary>
	/// Full version string in format: Major.Minor.Build
	/// </summary>
	public static string FullVersion => "$(ComputedVersion)"%3B

	/// <summary>
	/// Short version string in format: Major.Minor
	/// </summary>
	public static string ShortVersion => "$(VersionMajor).$(VersionMinor)"%3B
}
]]>
	  </VersionFileContent>
	</PropertyGroup>

	<!-- Write the generated file -->
	<WriteLinesToFile File="$(GeneratedVersionFile)" Lines="$(VersionFileContent)" Overwrite="true" />

	<Message Text="Building with version: $(ComputedVersion)" Importance="high" />
  </Target>

  <!-- Target: Increment Build Number After Successful Build -->
  <Target Name="IncrementBuildNumber" AfterTargets="Build" Condition="'$(BuildingProject)' == 'true'">
	<!-- Only increment on successful builds (no errors) -->
	<PropertyGroup>
	  <NewBuildNumber>$([MSBuild]::Add($(BuildNumber), 1))</NewBuildNumber>
	</PropertyGroup>

	<!-- Write the incremented build number back to file -->
	<WriteLinesToFile File="$(BuildNumberFile)" Lines="$(NewBuildNumber)" Overwrite="true" />

	<Message Text="Build successful! Incremented build number to: $(NewBuildNumber)" Importance="high" />
  </Target>

</Project>
