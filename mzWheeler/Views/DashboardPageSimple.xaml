<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:mzWheeler.Controls"
             x:Class="mzWheeler.Views.DashboardPageSimple"
             Title="Dashboard"
             BackgroundColor="#1a1a1a">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Header -->
            <Label 
                Text="Vehicle Dashboard"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalOptions="Center"
                Margin="0,10,0,20"/>

            <!-- Connection Status -->
            <Border Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#2a2a2a">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label 
                        Text="OBD-II Connection"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="White"/>
                    <Label 
                        Text="{Binding ConnectionStatus}"
                        FontSize="14"
                        TextColor="#888"
                        LineBreakMode="WordWrap"/>
                    <Button 
                        Text="Disconnect"
                        Command="{Binding DisconnectCommand}"
                        IsEnabled="{Binding IsConnected}"
                        BackgroundColor="#f44336"
                        TextColor="White"
                        Padding="15,10"
                        FontSize="12"
                        HorizontalOptions="Center"
                        WidthRequest="200"/>
                </VerticalStackLayout>
            </Border>

            <!-- Primary Metrics Row 1 -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="15">

                <!-- Speed Circular Gauge -->
                <Border Grid.Column="0" Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#2a2a2a">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Speed" FontSize="16" TextColor="#888" HorizontalOptions="Center"/>

                        <!-- Circular Gauge -->
                        <Grid WidthRequest="200" HeightRequest="200" HorizontalOptions="Center">
                            <!-- Custom Circular Gauge -->
                            <controls:CircularGauge 
                                Value="{Binding Speed}"
                                MinValue="0"
                                MaxValue="80"
                                ArcColor="#4CAF50"
                                BackgroundArcColor="#333333"
                                ArcThickness="20"
                                WidthRequest="200"
                                HeightRequest="200"/>

                            <!-- Center Value Display -->
                            <VerticalStackLayout HorizontalOptions="Center" 
                                               VerticalOptions="Center" 
                                               Spacing="2">
                                <Label Text="{Binding Speed, StringFormat='{0:F0}'}" 
                                       FontSize="48" 
                                       FontAttributes="Bold" 
                                       TextColor="#4CAF50"
                                       HorizontalTextAlignment="Center"/>
                                <Label Text="km/h" 
                                       FontSize="14" 
                                       TextColor="#888"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>

                            <!-- Gauge Markers -->
                            <Label Text="0" FontSize="10" TextColor="#666" 
                                 HorizontalOptions="Start" VerticalOptions="End" 
                                 Margin="10,0,0,10"/>
                            <Label Text="40" FontSize="10" TextColor="#666" 
                                 HorizontalOptions="Center" VerticalOptions="Start" 
                                 Margin="-30,10,0,0"/>
                            <Label Text="80" FontSize="10" TextColor="#666" 
                                 HorizontalOptions="End" VerticalOptions="End" 
                                 Margin="0,0,10,10"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- RPM Circular Gauge -->
                <Border Grid.Column="1" Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#2a2a2a">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="RPM" FontSize="16" TextColor="#888" HorizontalOptions="Center"/>

                        <!-- Circular Gauge -->
                        <Grid WidthRequest="200" HeightRequest="200" HorizontalOptions="Center">
                            <!-- Custom Circular Gauge -->
                            <controls:CircularGauge 
                                Value="{Binding Rpm}"
                                MinValue="0"
                                MaxValue="6500"
                                ArcColor="#2196F3"
                                BackgroundArcColor="#333333"
                                ArcThickness="20"
                                WidthRequest="200"
                                HeightRequest="200"/>

                            <!-- Center Value Display -->
                            <VerticalStackLayout HorizontalOptions="Center" 
                                               VerticalOptions="Center" 
                                               Spacing="2">
                                <Label Text="{Binding Rpm, StringFormat='{0:F0}'}" 
                                       FontSize="48" 
                                       FontAttributes="Bold" 
                                       TextColor="#2196F3"
                                       HorizontalTextAlignment="Center"/>
                                <Label Text="RPM" 
                                       FontSize="14" 
                                       TextColor="#888"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>

                            <!-- Gauge Markers -->
                            <Label Text="0" FontSize="10" TextColor="#666" 
                                 HorizontalOptions="Start" VerticalOptions="End" 
                                 Margin="10,0,0,10"/>
                            <Label Text="3k" FontSize="10" TextColor="#666" 
                                 HorizontalOptions="Center" VerticalOptions="Start" 
                                 Margin="-30,10,0,0"/>
                            <Label Text="6.5k" FontSize="10" TextColor="#666" 
                                 HorizontalOptions="End" VerticalOptions="End" 
                                 Margin="0,0,10,10"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Secondary Metrics Row 2 -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="15">

                <!-- Engine Load Bar Graph -->
                <Border Grid.Column="0" Stroke="#333" Padding="20" StrokeThickness="1" BackgroundColor="#2a2a2a">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Engine Load" 
                               FontSize="16" 
                               TextColor="#888" 
                               HorizontalOptions="Start"/>

                        <!-- Bar Graph with Overlay Text -->
                        <Grid HeightRequest="80">
                            <!-- Background Bar -->
                            <Border BackgroundColor="#1a1a1a" 
                                    Stroke="#666"
                                    StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="5"/>
                                </Border.StrokeShape>
                            </Border>

                            <!-- Progress Bar (horizontal bar graph) -->
                            <ProgressBar Progress="{Binding EngineLoad, Converter={StaticResource ProgressConverter}, ConverterParameter=100}" 
                                       ProgressColor="#9C27B0"
                                       VerticalOptions="Fill"
                                       Rotation="0"
                                       ScaleY="8"/>

                            <!-- Centered Text Overlay -->
                            <HorizontalStackLayout HorizontalOptions="Center" 
                                                 VerticalOptions="Center" 
                                                 Spacing="5">
                                <Label Text="{Binding EngineLoad, StringFormat='{0:F0}'}" 
                                       FontSize="42" 
                                       FontAttributes="Bold" 
                                       TextColor="White"
                                       VerticalTextAlignment="Center"/>
                                <Label Text="%" 
                                       FontSize="24" 
                                       FontAttributes="Bold" 
                                       TextColor="White"
                                       VerticalTextAlignment="Center"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Throttle Bar Graph -->
                <Border Grid.Column="1" Stroke="#333" Padding="20" StrokeThickness="1" BackgroundColor="#2a2a2a">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Throttle Position" 
                               FontSize="16" 
                               TextColor="#888" 
                               HorizontalOptions="Start"/>

                        <!-- Bar Graph with Overlay Text -->
                        <Grid HeightRequest="80">
                            <!-- Background Bar -->
                            <Border BackgroundColor="#1a1a1a" 
                                    Stroke="#666"
                                    StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="5"/>
                                </Border.StrokeShape>
                            </Border>

                            <!-- Progress Bar (horizontal bar graph) -->
                            <ProgressBar Progress="{Binding Throttle, Converter={StaticResource ProgressConverter}, ConverterParameter=100}" 
                                       ProgressColor="#FF9800"
                                       VerticalOptions="Fill"
                                       Rotation="0"
                                       ScaleY="8"/>

                            <!-- Centered Text Overlay -->
                            <HorizontalStackLayout HorizontalOptions="Center" 
                                                 VerticalOptions="Center" 
                                                 Spacing="5">
                                <Label Text="{Binding Throttle, StringFormat='{0:F0}'}" 
                                       FontSize="42" 
                                       FontAttributes="Bold" 
                                       TextColor="White"
                                       VerticalTextAlignment="Center"/>
                                <Label Text="%" 
                                       FontSize="24" 
                                       FontAttributes="Bold" 
                                       TextColor="White"
                                       VerticalTextAlignment="Center"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Additional Info Row 3 -->
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto" ColumnSpacing="10">

                <!-- Coolant Temp -->
                <Border Grid.Column="0" Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#2a2a2a">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Coolant" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                        <Label Text="{Binding CoolantTemp, StringFormat='{0:F0}°C'}" 
                               FontSize="24" 
                               FontAttributes="Bold" 
                               TextColor="#00BCD4" 
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Fuel Level -->
                <Border Grid.Column="1" Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#2a2a2a">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Fuel" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                        <Label Text="{Binding FuelLevel, StringFormat='{0:F0}%'}" 
                               FontSize="24" 
                               FontAttributes="Bold" 
                               TextColor="#FFC107" 
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Battery Voltage -->
                <Border Grid.Column="2" Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#2a2a2a">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Battery" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                        <Label Text="{Binding BatteryVoltage, StringFormat='{0:F1}V'}" 
                               FontSize="24" 
                               FontAttributes="Bold" 
                               TextColor="#8BC34A" 
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
