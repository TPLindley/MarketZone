<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:mzWheeler.Controls"
             x:Class="mzWheeler.Views.ConditionsPageSimple"
             Title="Conditions"
             BackgroundColor="#1a1a1a">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Header -->
            <Label 
                Text="GPS and Tilt Conditions"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalOptions="Center"
                Margin="0,10,0,20"/>

            <!-- Monitoring Controls -->
            <Border Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#2a2a2a">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label 
                        Text="Sensor Monitoring"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="White"/>
                    <Label 
                        Text="{Binding MonitoringStatus}"
                        FontSize="14"
                        TextColor="#888"/>
                    <HorizontalStackLayout Spacing="10">
                        <Button 
                            Text="Start"
                            Command="{Binding StartMonitoringCommand}"
                            IsEnabled="{Binding IsMonitoring, Converter={StaticResource InvertedBoolConverter}}"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            Padding="20,10"/>
                        <Button 
                            Text="Stop"
                            Command="{Binding StopMonitoringCommand}"
                            IsEnabled="{Binding IsMonitoring}"
                            BackgroundColor="#f44336"
                            TextColor="White"
                            Padding="20,10"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- GPS Location Section -->
            <Border Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#2a2a2a">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">
                    <Label 
                        Text="GPS Location"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="White"/>

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <Label Grid.Row="0" Grid.Column="0" Text="Latitude:" FontSize="14" TextColor="#888"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Latitude, StringFormat='{0:F6}°'}" FontSize="14" TextColor="White"/>

                        <Label Grid.Row="1" Grid.Column="0" Text="Longitude:" FontSize="14" TextColor="#888"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Longitude, StringFormat='{0:F6}°'}" FontSize="14" TextColor="White"/>

                        <Label Grid.Row="2" Grid.Column="0" Text="Altitude:" FontSize="14" TextColor="#888"/>
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding Altitude, StringFormat='{0:F1} m'}" FontSize="14" TextColor="White"/>

                        <Label Grid.Row="3" Grid.Column="0" Text="Accuracy:" FontSize="14" TextColor="#888"/>
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding Accuracy, StringFormat='{0:F1} m'}" FontSize="14" TextColor="White"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- GPS Speed and Course Row -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="15">

                <!-- GPS Speed Gauge -->
                <Border Grid.Column="0" Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#2a2a2a">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="GPS Speed" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>

                        <Grid WidthRequest="180" HeightRequest="180" HorizontalOptions="Center">
                            <controls:CircularGauge 
                                Value="{Binding GpsSpeed}"
                                MinValue="0"
                                MaxValue="80"
                                ArcColor="#4CAF50"
                                BackgroundArcColor="#333"
                                ArcThickness="12"/>

                            <!-- Centered value display -->
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                                <Label Text="{Binding GpsSpeed, StringFormat='{0:F0}'}" 
                                       FontSize="48" 
                                       FontAttributes="Bold" 
                                       TextColor="#4CAF50" 
                                       HorizontalOptions="Center"/>
                                <Label Text="km/h" FontSize="14" TextColor="#888" HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <!-- Gauge Markers -->
                            <Label Text="0" FontSize="10" TextColor="#666" 
                                  HorizontalOptions="Start" VerticalOptions="End" 
                                  Margin="10,0,0,20"/>
                            <Label Text="40" FontSize="10" TextColor="#666" 
                                  HorizontalOptions="Center" VerticalOptions="Start" 
                                  Margin="0,5,0,0"/>
                            <Label Text="80" FontSize="10" TextColor="#666" 
                                  HorizontalOptions="End" VerticalOptions="End" 
                                  Margin="0,0,10,20"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Heading Gauge -->
                <Border Grid.Column="1" Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#2a2a2a">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Heading" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>

                        <Grid WidthRequest="200" HeightRequest="200" HorizontalOptions="Center">
                            <controls:CompassGaugeView 
                                Heading="{Binding Course}"
                                ArcColor="#2196F3"
                                BackgroundArcColor="#333"
                                ArcThickness="12"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Tilt Section -->
            <Border Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#2a2a2a">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">
                    <Label 
                        Text="Device Orientation"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="White"
                        HorizontalOptions="Center"/>

                    <!-- 3D Tilt Sphere -->
                    <controls:TiltSphereView 
                        Pitch="{Binding Pitch}"
                        Roll="{Binding Roll}"
                        Yaw="{Binding Yaw}"
                        WidthRequest="300"
                        HeightRequest="300"
                        HorizontalOptions="Center"/>

                    <!-- Numeric readouts below sphere -->
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="Pitch" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                            <Label Text="{Binding Pitch, StringFormat='{0:F1}°'}" 
                                   FontSize="18" 
                                   FontAttributes="Bold" 
                                   TextColor="#9C27B0" 
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="Roll" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                            <Label Text="{Binding Roll, StringFormat='{0:F1}°'}" 
                                   FontSize="18" 
                                   FontAttributes="Bold" 
                                   TextColor="#FF9800" 
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" Spacing="5">
                            <Label Text="Yaw" FontSize="12" TextColor="#888" HorizontalOptions="Center"/>
                            <Label Text="{Binding Yaw, StringFormat='{0:F1}°'}" 
                                   FontSize="18" 
                                   FontAttributes="Bold" 
                                   TextColor="#00BCD4" 
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
