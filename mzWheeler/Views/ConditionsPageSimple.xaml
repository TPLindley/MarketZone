<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mzWheeler.Views.ConditionsPageSimple"
             Title="Conditions"
             BackgroundColor="#1a1a1a">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Header -->
            <Label 
                Text="GPS and Tilt Conditions"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalOptions="Center"
                Margin="0,10,0,20"/>

            <!-- Monitoring Controls -->
            <Border Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#2a2a2a">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label 
                        Text="Sensor Monitoring"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="White"/>
                    <Label 
                        Text="{Binding MonitoringStatus}"
                        FontSize="14"
                        TextColor="#888"/>
                    <HorizontalStackLayout Spacing="10">
                        <Button 
                            Text="Start"
                            Command="{Binding StartMonitoringCommand}"
                            IsEnabled="{Binding IsMonitoring, Converter={StaticResource InvertedBoolConverter}}"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            Padding="20,10"/>
                        <Button 
                            Text="Stop"
                            Command="{Binding StopMonitoringCommand}"
                            IsEnabled="{Binding IsMonitoring}"
                            BackgroundColor="#f44336"
                            TextColor="White"
                            Padding="20,10"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- GPS Location Section -->
            <Border Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#2a2a2a">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">
                    <Label 
                        Text="GPS Location"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="White"/>

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <Label Grid.Row="0" Grid.Column="0" Text="Latitude:" FontSize="14" TextColor="#888"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Latitude, StringFormat='{0:F6}°'}" FontSize="14" TextColor="White"/>

                        <Label Grid.Row="1" Grid.Column="0" Text="Longitude:" FontSize="14" TextColor="#888"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Longitude, StringFormat='{0:F6}°'}" FontSize="14" TextColor="White"/>

                        <Label Grid.Row="2" Grid.Column="0" Text="Altitude:" FontSize="14" TextColor="#888"/>
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding Altitude, StringFormat='{0:F1} m'}" FontSize="14" TextColor="White"/>

                        <Label Grid.Row="3" Grid.Column="0" Text="Accuracy:" FontSize="14" TextColor="#888"/>
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding Accuracy, StringFormat='{0:F1} m'}" FontSize="14" TextColor="White"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- GPS Speed and Course Row -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="15">

                <!-- GPS Speed -->
                <Border Grid.Column="0" Stroke="#333" Padding="20" StrokeThickness="1" BackgroundColor="#2a2a2a">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="GPS Speed" FontSize="16" TextColor="#888" HorizontalOptions="Center"/>
                        <Label Text="{Binding GpsSpeed, StringFormat='{0:F0}'}" 
                               FontSize="48" 
                               FontAttributes="Bold" 
                               TextColor="#4CAF50" 
                               HorizontalOptions="Center"/>
                        <Label Text="km/h" FontSize="14" TextColor="#888" HorizontalOptions="Center"/>
                        <ProgressBar Progress="{Binding GpsSpeed, Converter={StaticResource ProgressConverter}, ConverterParameter=200}" 
                                   ProgressColor="#4CAF50"
                                   HeightRequest="10"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Course/Heading -->
                <Border Grid.Column="1" Stroke="#333" Padding="20" StrokeThickness="1" BackgroundColor="#2a2a2a">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Heading" FontSize="16" TextColor="#888" HorizontalOptions="Center"/>
                        <Label Text="{Binding Course, StringFormat='{0:F0}°'}" 
                               FontSize="48" 
                               FontAttributes="Bold" 
                               TextColor="#2196F3" 
                               HorizontalOptions="Center"/>
                        <Label Text="{Binding CourseDirection}" FontSize="14" TextColor="#888" HorizontalOptions="Center"/>
                        <ProgressBar Progress="{Binding Course, Converter={StaticResource ProgressConverter}, ConverterParameter=360}" 
                                   ProgressColor="#2196F3"
                                   HeightRequest="10"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Tilt Section -->
            <Border Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#2a2a2a">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">
                    <Label 
                        Text="Device Tilt"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="White"/>

                    <!-- Pitch, Roll, Yaw -->
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto" ColumnSpacing="10">

                        <!-- Pitch -->
                        <Border Grid.Column="0" Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#1a1a1a">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Pitch" FontSize="14" TextColor="#888" HorizontalOptions="Center"/>
                                <Label Text="{Binding Pitch, StringFormat='{0:F1}°'}" 
                                       FontSize="28" 
                                       FontAttributes="Bold" 
                                       TextColor="#9C27B0" 
                                       HorizontalOptions="Center"/>
                                <ProgressBar Progress="{Binding Pitch, Converter={StaticResource ProgressConverter}, ConverterParameter=90}" 
                                           ProgressColor="#9C27B0"
                                           HeightRequest="6"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Roll -->
                        <Border Grid.Column="1" Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#1a1a1a">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Roll" FontSize="14" TextColor="#888" HorizontalOptions="Center"/>
                                <Label Text="{Binding Roll, StringFormat='{0:F1}°'}" 
                                       FontSize="28" 
                                       FontAttributes="Bold" 
                                       TextColor="#FF9800" 
                                       HorizontalOptions="Center"/>
                                <ProgressBar Progress="{Binding Roll, Converter={StaticResource ProgressConverter}, ConverterParameter=90}" 
                                           ProgressColor="#FF9800"
                                           HeightRequest="6"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Yaw -->
                        <Border Grid.Column="2" Stroke="#333" Padding="15" StrokeThickness="1" BackgroundColor="#1a1a1a">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="Yaw" FontSize="14" TextColor="#888" HorizontalOptions="Center"/>
                                <Label Text="{Binding Yaw, StringFormat='{0:F1}°'}" 
                                       FontSize="28" 
                                       FontAttributes="Bold" 
                                       TextColor="#00BCD4" 
                                       HorizontalOptions="Center"/>
                                <ProgressBar Progress="{Binding Yaw, Converter={StaticResource ProgressConverter}, ConverterParameter=360}" 
                                           ProgressColor="#00BCD4"
                                           HeightRequest="6"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
