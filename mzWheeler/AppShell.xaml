<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="mzWheeler.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:mzWheeler.Views"
    Title="mzWheeler">

    <TabBar>
        <ShellContent
            Title="Dashboard"
            Icon="dashboard.png"
            ContentTemplate="{DataTemplate views:DashboardPageSimple}"
            Route="DashboardPage" />

        <ShellContent
            Title="Conditions"
            Icon="map.png"
            ContentTemplate="{DataTemplate views:ConditionsPageSimple}"
            Route="ConditionsPage" />
    </TabBar>

</Shell>
